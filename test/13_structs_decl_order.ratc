struct PointZ {
    Point p;
    int z;
}

struct Point {
    int x;
    int y;
}

// Entry-point. Should return true if errors occurred
fn bool program(){
    Point a;
    Point b;
    a.x = 12;
    a.y = 15;
    b.x = 22;
    PointZ z;
    z.p = a;
    z.z = b.x;
    echo (z.p.x + b.x);
    return false;
}
